NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# IA planning (server)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Ticketing + Gmail Workspace (Cloud Run worker)
# El worker lee/envía correo con la Gmail API usando la cuenta de servicio
# (FIREBASE_SERVICE_ACCOUNT_JSON) con domain-wide delegation impersonando GMAIL_USER.
SUPPORT_EMAIL=help@formeta.es
SUPPORT_FROM_NAME=Formeta Soporte
TICKET_PUBLIC_BASE_URL=https://formeta.es/intranet/tickets
TICKET_WORKER_POLL_SECONDS=60
TICKET_MAX_ATTACHMENT_MB=20
TICKET_REOPEN_WINDOW_DAYS=14
GMAIL_USER=formeta@formeta.es
# Cuenta de servicio con domain-wide delegation para Gmail (puede ser distinta
# a la de Firebase). Si se omite, el worker usa FIREBASE_SERVICE_ACCOUNT_JSON.
GMAIL_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_STORAGE_BUCKET=fmeta-f9aed.firebasestorage.app

# ForMeta backend services (server only)
FISCAL_API_BASE_URL=https://fiscal.formeta.es
RAG_API_BASE_URL=https://frag.formeta.es
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Verifactu / AEAT client (server only)
VERIFACTU_AEAT_MOCK=true
AEAT_VERIFACTU_ENDPOINT=
AEAT_CERTIFICATE_ALIAS=
AEAT_CERTIFICATE_P12_BASE64=
AEAT_CERTIFICATE_PASSWORD=

# GitHub Issues integration (server, fine-grained PAT con read-only de Issues)
GITHUB_TOKEN=
