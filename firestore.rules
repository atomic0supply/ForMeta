rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Clientes
    match /clients/{clientId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // Proyectos y sus subcolecciones
    match /projects/{projectId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAuth();

      match /endpoints/{endpointId} {
        allow read, write: if isAuth();
      }

      match /tasks/{taskId} {
        allow read, write: if isAuth();

        match /comments/{commentId} {
          allow read, create: if isAuth();
          allow update, delete: if isAuth() && (
            resource.data.authorUid == request.auth.uid || isAdmin()
          );
        }
      }

      match /externalApis/{apiId} {
        allow read, write: if isAuth();
      }

      match /wiki/{pageId} {
        allow read, write: if isAuth();
      }
    }

    // Entradas de tiempo
    match /timeEntries/{entryId} {
      allow read, create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
    }

    // Links globales (bookmarks)
    match /links/{linkId} {
      allow read, write: if isAuth();
    }

    // Ticketing interno
    match /tickets/{ticketId} {
      allow read, create, update: if isAuth();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, create: if isAuth();
        allow update, delete: if isAdmin();
      }

      match /events/{eventId} {
        allow read, create: if isAuth();
        allow update, delete: if false;
      }
    }

    match /ticketMailOutbox/{outboxId} {
      allow read, create, update: if isAuth();
      allow delete: if isAdmin();
    }

    match /ticketProcessingErrors/{errorId} {
      allow read, create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // Propuestas / presupuestos al cliente.
    // Inmutables una vez facturadas (convertedInvoiceId fijado) salvo admin.
    match /proposals/{proposalId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        isAdmin() || resource.data.convertedInvoiceId == "" ||
        !("convertedInvoiceId" in resource.data)
      );
      allow delete: if isAdmin();
    }

    // Cola de notificaciones a clientes (la envía el worker con Admin SDK, que
    // ignora estas reglas). El frontend solo puede crear borradores y mover
    // draft/failed → draft (editar) o → approved (aprobar = disparar envío, solo
    // admin). Los estados sending/sent/failed los fija únicamente el worker, así
    // que un correo ya enviado no puede reabrirse ni reenviarse desde la UI.
    match /clientMailOutbox/{outboxId} {
      allow read: if isAuth();
      // Regla general: los correos a cliente se crean como borrador y un admin los
      // aprueba. Excepción: el acuse de apertura de ticket (kind == "ticket_opened")
      // es transaccional y se crea ya aprobado para que el worker lo envíe al instante.
      allow create: if isAuth() && (
        request.resource.data.status == "draft"
        || (request.resource.data.status == "approved"
            && request.resource.data.kind == "ticket_opened")
      );
      allow update: if isAuth()
        && resource.data.status in ["draft", "failed"]
        && (
          request.resource.data.status == "draft"
          || (request.resource.data.status == "approved" && isAdmin())
        );
      allow delete: if isAdmin();
    }

    match /clientMailProcessingErrors/{errorId} {
      allow read, create, update: if isAuth();
      allow delete: if isAdmin();
    }

    match /ticketSettings/{settingsId} {
      allow read: if isAuth();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /systemCounters/{counterId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Ideas de negocio/desarrollo con análisis IA
    match /ideas/{ideaId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Búsqueda global: collectionGroup("tasks") requiere regla con wildcard de ruta
    match /{path=**}/tasks/{taskId} {
      allow read: if isAuth();
    }

    // Vista global de APIs: collectionGroup("externalApis") requiere wildcard de ruta
    match /{path=**}/externalApis/{apiId} {
      allow read: if isAuth();
    }

    // Dominios
    match /domains/{domainId} {
      allow read, write: if isAuth();
    }

    // Servicios (infraestructura contratada)
    match /services/{serviceId} {
      allow read, write: if isAuth();
    }

    // Licencias de software
    match /licenses/{licenseId} {
      allow read, write: if isAuth();
    }

    // Correo: alias / buzones de Workspace
    match /mailboxes/{mailboxId} {
      allow read, write: if isAuth();
    }

    // Log de actividad — inmutable salvo lectura
    match /activityLog/{eventId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // Núcleo fiscal y facturación
    match /fiscalProfiles/{profileId} {
      allow read, create, update: if isAuth();
      allow delete: if false;
    }

    match /invoices/{invoiceId} {
      allow read, create: if isAuth();
      allow update: if isAuth() && resource.data.status == "issued" && (
        request.resource.data.status == "cancelled" ||
        (
          request.resource.data.status == "issued" &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["paymentStatus", "paidAt", "paidAmount"])
        )
      );
      allow delete: if false;
    }

    match /fiscalEvents/{eventId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    match /fiscalLedger/{entryId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    match /expenses/{expenseId} {
      allow read, create, update: if isAuth();
      allow delete: if false;
    }

    match /recurringExpenses/{expenseId} {
      allow read, create, update: if isAuth();
      allow delete: if false;
    }

    match /quarterlyClosures/{closureId} {
      allow read, create, update: if isAuth();
      allow delete: if false;
    }

    match /fiscalWatcherAlerts/{alertId} {
      allow read, create, update: if isAuth();
      allow delete: if false;
    }

    match /fiscalWatcherSources/{sourceId} {
      allow read, create, update: if isAuth();
      allow delete: if false;
    }

    match /verifactuConfig/{configId} {
      allow read, create, update: if isAuth();
      allow delete: if false;
    }

    match /verifactuRecords/{recordId} {
      allow read, create, update: if isAuth();
      allow delete: if false;
    }

    match /fiscalCounters/{counterId} {
      allow read, create, update: if isAuth();
      allow delete: if false;
    }

    // Perfiles de usuario
    // Cualquier usuario autenticado puede leer la lista (necesario para selector de asignados)
    // Solo el propio usuario puede actualizar su perfil; solo admins pueden gestionar otros
    match /users/{uid} {
      allow read: if isAuth();
      allow update: if isAuth() && request.auth.uid == uid;
      allow create, delete: if isAdmin();
      allow update: if isAdmin();
    }

    // Roles dinámicos: cualquier usuario autenticado puede leerlos (para resolver
    // sus módulos permitidos); solo los admins pueden crearlos/editarlos/borrarlos.
    match /roles/{roleId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }
  }
}
