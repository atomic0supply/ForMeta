rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Clientes
    match /clients/{clientId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // Proyectos y sus subcolecciones
    match /projects/{projectId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAuth();

      match /endpoints/{endpointId} {
        allow read, write: if isAuth();
      }

      match /tasks/{taskId} {
        allow read, write: if isAuth();

        match /comments/{commentId} {
          allow read, create: if isAuth();
          allow update, delete: if isAuth() && (
            resource.data.authorUid == request.auth.uid || isAdmin()
          );
        }
      }

      match /externalApis/{apiId} {
        allow read, write: if isAuth();
      }

      match /wiki/{pageId} {
        allow read, write: if isAuth();
      }
    }

    // Entradas de tiempo
    match /timeEntries/{entryId} {
      allow read, create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
    }

    // Links globales (bookmarks)
    match /links/{linkId} {
      allow read, write: if isAuth();
    }

    // Ideas de negocio/desarrollo con análisis IA
    match /ideas/{ideaId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Búsqueda global: collectionGroup("tasks") requiere regla con wildcard de ruta
    match /{path=**}/tasks/{taskId} {
      allow read: if isAuth();
    }

    // Dominios
    match /domains/{domainId} {
      allow read, write: if isAuth();
    }

    // Log de actividad — inmutable salvo lectura
    match /activityLog/{eventId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // Perfiles de usuario
    // Cualquier usuario autenticado puede leer la lista (necesario para selector de asignados)
    // Solo el propio usuario puede actualizar su perfil; solo admins pueden gestionar otros
    match /users/{uid} {
      allow read: if isAuth();
      allow update: if isAuth() && request.auth.uid == uid;
      allow create, delete: if isAdmin();
      allow update: if isAdmin();
    }
  }
}
