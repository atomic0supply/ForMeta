rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuth() {
      return request.auth != null;
    }

    match /tickets/{ticketId}/{allPaths=**} {
      allow read: if isAuth();
      // Cap de tamaño para subidas desde la UI (el worker usa Admin SDK y no
      // pasa por estas reglas).
      allow write: if isAuth() && request.resource.size < 20 * 1024 * 1024;
    }
  }
}
